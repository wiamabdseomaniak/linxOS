generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatutPreparation {
  en_attente
  en_preparation
  prete
  terminee
}

enum StatutLivraison {
  planifie
  en_cours
  livree
  echouee
}

enum StatutTracking {
  planifie
  en_preparation
  prete
  en_cours
  livree
  echouee
}

model Utilisateur {
  id_utilisateur String    @id @default(dbgenerated("gen_random_uuid()"))
  nom            String
  prenom         String
  email          String    @unique
  tele           String?
  mot_de_passe   String
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())

  livraisons    Livraison[]
  notifications Notification[]

  @@map("utilisateur")
}

model Client {
  id_client   String   @id @default(dbgenerated("gen_random_uuid()"))
  nom_complet String
  telephone   String?
  email       String?
  adresse     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  livraisons Livraison[]

  @@map("client")
}

model Livraison {
  id_livraison         String            @id @default(dbgenerated("gen_random_uuid()"))
  nom_evenement        String
  organisateur         String
  adresse_livraison    String
  ville                String
  date_prevue          DateTime
  quantite             Int               @default(0)
  statut_preparation   String            @default("en_attente")
  statut_livraison     String            @default("planifie")
  description_probleme String?
  id_client            String?
  id_utilisateur       String?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @default(now())

  client      Client?      @relation(fields: [id_client], references: [id_client], onDelete: SetNull)
  utilisateur Utilisateur? @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: SetNull)
  trackings   Tracking[]
  notes       Note[]

  @@index([statut_preparation])
  @@index([statut_livraison])
  @@index([ville])
  @@index([date_prevue])
  @@index([id_client])
  @@map("livraison")
}

model Tracking {
  id_tracking   String   @id @default(dbgenerated("gen_random_uuid()"))
  statut        String
  date_tracking DateTime @default(now())
  description   String?
  id_livraison  String?
  created_at    DateTime @default(now())

  livraison Livraison? @relation(fields: [id_livraison], references: [id_livraison], onDelete: Cascade)

  @@index([id_livraison])
  @@index([date_tracking])
  @@map("tracking")
}

model Note {
  id_note      String   @id @default(dbgenerated("gen_random_uuid()"))
  contenu      String
  date_note    DateTime @default(now())
  id_livraison String?

  livraison Livraison? @relation(fields: [id_livraison], references: [id_livraison], onDelete: Cascade)

  @@index([id_livraison])
  @@map("note")
}

model Notification {
  id_notification   String   @id @default(dbgenerated("gen_random_uuid()"))
  titre             String
  message           String
  date_notification DateTime @default(now())
  lue               Boolean  @default(false)
  id_utilisateur    String?

  utilisateur Utilisateur? @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade)

  @@index([id_utilisateur])
  @@index([lue])
  @@index([date_notification])
  @@map("notification")
}

model EmailVerification {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  email          String
  code_hash      String
  expires_at     DateTime
  attempts       Int      @default(0)
  resend_attempts Int     @default(0)
  used           Boolean  @default(false)
  created_at     DateTime @default(now())

  @@index([email])
  @@index([expires_at])
  @@map("email_verifications")
}
